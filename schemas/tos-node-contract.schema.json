{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/Tree-of-Sophia/main/schemas/tos-node-contract.schema.json",
  "title": "ToS node contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "node_id",
    "node_type",
    "source_anchor",
    "key_terms",
    "distilled_thesis",
    "interpretation_layers"
  ],
  "anyOf": [
    {
      "required": [
        "relations"
      ]
    },
    {
      "required": [
        "lineage_relations"
      ]
    }
  ],
  "properties": {
    "node_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^tos\\.(source|concept|lineage|context|synthesis)\\.[a-z0-9]+(?:-[a-z0-9]+)*(?:\\.[a-z0-9]+(?:-[a-z0-9]+)*)*$"
    },
    "node_type": {
      "type": "string",
      "enum": [
        "source",
        "concept",
        "lineage",
        "context",
        "synthesis"
      ]
    },
    "source_anchor": {
      "type": "string",
      "minLength": 1
    },
    "key_terms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "distilled_thesis": {
      "type": "string",
      "minLength": 1
    },
    "relations": {
      "description": "Preferred public relation field for current ToS nodes.",
      "$ref": "#/$defs/relationsArray"
    },
    "lineage_relations": {
      "description": "Legacy compatibility alias; prefer 'relations' for current public surfaces.",
      "$ref": "#/$defs/relationsArray"
    },
    "interpretation_layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "source_linked",
          "distilled_thesis",
          "commentary",
          "cross_text_comparison",
          "speculative_synthesis"
        ]
      },
      "uniqueItems": true
    },
    "language_witnesses": {
      "description": "Optional multilingual witness layers for one shared authored node.",
      "$ref": "#/$defs/languageWitnessesArray"
    },
    "translation_tensions": {
      "description": "Optional notes for philosophically load-bearing witness drift.",
      "$ref": "#/$defs/translationTensionsArray"
    }
  },
  "$defs": {
    "relationsArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relation",
          "target_ref"
        ],
        "properties": {
          "relation": {
            "type": "string",
            "enum": [
              "predecessor",
              "descendant",
              "parallel",
              "mutation",
              "tension",
              "commentary-on",
              "contextualized-by"
            ]
          },
          "target_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "languageWitnessesArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "language",
          "role",
          "segments"
        ],
        "properties": {
          "language": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "canonical_source",
              "working_translation",
              "bridge_translation"
            ]
          },
          "segments": {
            "$ref": "#/$defs/witnessSegmentsArray"
          }
        }
      }
    },
    "witnessSegmentsArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "segment_id",
          "text"
        ],
        "properties": {
          "segment_id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "translationTensionsArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "segment_id",
          "note"
        ],
        "properties": {
          "segment_id": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
