{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/Tree-of-Sophia/main/schemas/tos-node-contract.schema.json",
  "title": "ToS node contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "node_id",
    "node_type",
    "source_anchor",
    "key_terms",
    "distilled_thesis",
    "interpretation_layers"
  ],
  "anyOf": [
    {
      "required": [
        "relations"
      ]
    },
    {
      "required": [
        "lineage_relations"
      ]
    }
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "node_type": {
            "const": "source"
          }
        },
        "required": [
          "node_type"
        ]
      },
      "else": {
        "not": {
          "anyOf": [
            {
              "required": [
                "language_witnesses"
              ]
            },
            {
              "required": [
                "translation_tensions"
              ]
            }
          ]
        }
      }
    }
  ],
  "properties": {
    "node_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^tos\\.(source|concept|principle|lineage|event|state|support|context|synthesis)\\.[a-z0-9]+(?:-[a-z0-9]+)*(?:\\.[a-z0-9]+(?:-[a-z0-9]+)*)*$"
    },
    "node_type": {
      "type": "string",
      "enum": [
        "source",
        "concept",
        "principle",
        "lineage",
        "event",
        "state",
        "support",
        "context",
        "synthesis"
      ]
    },
    "source_anchor": {
      "type": "string",
      "minLength": 1
    },
    "key_terms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "distilled_thesis": {
      "type": "string",
      "minLength": 1
    },
    "relations": {
      "description": "Preferred public relation field for current ToS nodes.",
      "$ref": "#/$defs/relationsArray"
    },
    "lineage_relations": {
      "description": "Legacy compatibility alias; prefer 'relations' for current public surfaces.",
      "$ref": "#/$defs/relationsArray"
    },
    "interpretation_layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "source_linked",
          "distilled_thesis",
          "commentary",
          "cross_text_comparison",
          "speculative_synthesis"
        ]
      },
      "uniqueItems": true
    },
    "language_witnesses": {
      "description": "Optional multilingual witness layers for one shared authored node.",
      "$ref": "#/$defs/languageWitnessesArray"
    },
    "translation_tensions": {
      "description": "Optional notes for philosophically load-bearing witness drift.",
      "$ref": "#/$defs/translationTensionsArray"
    }
  },
  "$defs": {
    "relationsArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relation",
          "target_ref"
        ],
        "properties": {
          "relation": {
            "type": "string",
            "enum": [
              "predecessor",
              "descendant",
              "parallel",
              "mutation",
              "tension",
              "commentary-on",
              "contextualized-by"
            ]
          },
          "target_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "languageWitnessesArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "language",
          "role",
          "segments"
        ],
        "properties": {
          "language": {
            "type": "string",
            "enum": [
              "de",
              "ru",
              "en"
            ]
          },
          "role": {
            "type": "string",
            "enum": [
              "canonical_source",
              "working_translation",
              "bridge_translation"
            ]
          },
          "segments": {
            "$ref": "#/$defs/witnessSegmentsArray"
          },
          "witness_ref": {
            "type": "string",
            "minLength": 1,
            "description": "Bounded bibliographic or maintainer-facing witness reference."
          },
          "edition_or_source": {
            "type": "string",
            "minLength": 1,
            "description": "Edition, source surface, or maintainer posture for this witness."
          },
          "translator_or_editor": {
            "type": "string",
            "minLength": 1,
            "description": "Optional translator or editor attribution when it is part of the witness posture."
          },
          "publication_year": {
            "type": "string",
            "minLength": 1,
            "description": "Optional publication year or bounded year note for the witness."
          },
          "normalization_note": {
            "type": "string",
            "minLength": 1,
            "description": "Optional note about spelling or formatting normalization in the public witness surface."
          }
        }
      },
      "allOf": [
      {
        "contains": {
          "type": "object",
          "required": [
            "role"
          ],
          "properties": {
            "role": {
              "const": "canonical_source"
            }
          }
        },
        "minContains": 0,
        "maxContains": 1
      },
      {
        "contains": {
          "type": "object",
          "required": [
            "role"
          ],
          "properties": {
            "role": {
              "const": "working_translation"
            }
          }
        },
        "minContains": 0,
        "maxContains": 1
      },
      {
        "contains": {
          "type": "object",
          "required": [
            "role"
          ],
          "properties": {
            "role": {
              "const": "bridge_translation"
            }
          }
        },
        "minContains": 0,
        "maxContains": 1
      },
      {
        "contains": {
          "type": "object",
          "required": [
            "language"
          ],
          "properties": {
            "language": {
              "const": "de"
            }
          }
        },
        "minContains": 0,
        "maxContains": 1
      },
      {
        "contains": {
          "type": "object",
          "required": [
            "language"
          ],
          "properties": {
            "language": {
              "const": "ru"
            }
          }
        },
        "minContains": 0,
        "maxContains": 1
      },
      {
        "contains": {
          "type": "object",
          "required": [
            "language"
          ],
          "properties": {
            "language": {
              "const": "en"
            }
          }
        },
        "minContains": 0,
        "maxContains": 1
      }
    ]
    },
    "witnessSegmentsArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "segment_id",
          "text"
        ],
        "properties": {
          "segment_id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string",
            "minLength": 1,
            "description": "Optional bounded locator for the shared segment slice."
          }
        }
      }
    },
    "translationTensionsArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "segment_id",
          "note"
        ],
        "properties": {
          "segment_id": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
