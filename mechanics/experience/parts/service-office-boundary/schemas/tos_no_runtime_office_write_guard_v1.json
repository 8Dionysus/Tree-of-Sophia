{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/Tree-of-Sophia/mechanics/experience/parts/service-office-boundary/schemas/tos_no_runtime_office_write_guard_v1.json",
  "title": "Tos No Runtime Office Write Guard V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "blocked_actions",
    "created_at",
    "evidence_refs",
    "id",
    "kind",
    "notes",
    "owner_repo",
    "status",
    "target",
    "version"
  ],
  "properties": {
    "blocked_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "enum": [
          "runtime_write",
          "direct_service_write",
          "direct_office_train_write"
        ]
      },
      "minItems": 3,
      "allOf": [
        {
          "contains": {
            "const": "runtime_write"
          }
        },
        {
          "contains": {
            "const": "direct_service_write"
          }
        },
        {
          "contains": {
            "const": "direct_office_train_write"
          }
        }
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "tos_no_runtime_office_write_guard_v1"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1,
      "const": "Tree-of-Sophia"
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "active",
        "allowed",
        "applied",
        "blocked",
        "completed",
        "draft",
        "failed",
        "held",
        "passed",
        "proposed",
        "rejected",
        "rolled_back",
        "sealed"
      ]
    },
    "target": {
      "type": "string",
      "minLength": 1,
      "const": "Tree-of-Sophia"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "const": "1.1.0"
    }
  }
}
