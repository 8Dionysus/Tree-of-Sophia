    "abyss-machine artifacts verify BUNDLE_DIR",
    "abyss-machine artifacts release-check BUNDLE_DIR",
    "abyss-machine artifacts bundle-register BUNDLE_DIR --registry-dir REGISTRY_DIR --lifecycle-state release-ready --json",
    "abyss-machine artifacts materialize-subjects BUNDLE_DIR --registry-dir REGISTRY_DIR --manifest mechanics/release-support/parts/artifact-bundles/manifests/generated_readmodel.bundle.json --json",
    "abyss-machine artifacts trust-gate --registry-dir REGISTRY_DIR --artifact-class tree_of_sophia_generated_readmodel_bundle --consumer-intent agent --source-repo Tree-of-Sophia --json",
    "abyss-machine artifacts registry-latest --registry-dir REGISTRY_DIR --artifact-class tree_of_sophia_generated_readmodel_bundle --consumer-intent agent --source-repo Tree-of-Sophia --json"
  ]
