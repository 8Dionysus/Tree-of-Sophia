    "promotion_path": [
      "candidate",
      "built-local",
      "manually-verified",
      "release-ready",
      "published",
      "superseded",
      "revoked"
    ],
    "latest_eligible_states": [
      "manually-verified",
      "release-ready",
      "published"
    ]
  },
  "consumer_contract": {
