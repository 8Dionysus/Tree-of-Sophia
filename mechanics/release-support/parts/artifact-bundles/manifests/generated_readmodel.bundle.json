    "registry_required": true
  },
  "consumer_command": [
    "abyss-machine artifacts build-sidecars --manifest mechanics/release-support/parts/artifact-bundles/manifests/generated_readmodel.bundle.json --bundle-dir BUNDLE_DIR",
