{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tree-of-sophia.local/ToS/contracts/philosophy-graph-views.schema.json",
  "title": "Tree of Sophia philosophy graph view catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "source_view_contract_ref",
    "source_view_root",
    "atlas_projection_ref",
    "runtime_projection_boundary",
    "validation_refs",
    "counts",
    "graph_layers",
    "views",
    "diagnostics"
  ],
  "properties": {
    "schema_version": {
      "const": "tos_philosophy_graph_views_v1"
    },
    "schema_ref": {
      "const": "ToS/contracts/philosophy-graph-views.schema.json"
    },
    "owner_repo": {
      "const": "Tree-of-Sophia"
    },
    "surface_kind": {
      "const": "derived_philosophy_graph_view_catalog"
    },
    "source_view_contract_ref": {
      "const": "ToS/philosophy/graph-workbench/views/view-contracts.json"
    },
    "source_view_root": {
      "const": "ToS/philosophy/graph-workbench/views"
    },
    "atlas_projection_ref": {
      "const": "ToS/derived-exports/philosophy_atlas_projection.min.json"
    },
    "runtime_projection_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_owner", "runtime_scope", "tos_authority_scope"],
      "properties": {
        "runtime_owner": {
          "const": "abyss-stack"
        },
        "runtime_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tos_authority_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validation_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "graph_layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/graph_layer"
      }
    },
    "views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/view"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    }
  },
  "$defs": {
    "graph_layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer_id", "use", "source_ref"],
      "properties": {
        "layer_id": {
          "type": "string",
          "minLength": 1
        },
        "use": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "view_id",
        "title",
        "route_card",
        "source_ref",
        "order",
        "lens",
        "future_inputs",
        "boundary",
        "graph_layers",
        "current_projection_filters",
        "future_branch_filters",
        "layout_hint",
        "group_by",
        "sort_fields"
      ],
      "properties": {
        "view_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "route_card": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "lens": {
          "type": "string",
          "minLength": 1
        },
        "future_inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "boundary": {
          "type": "string",
          "minLength": 1
        },
        "graph_layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "current_projection_filters": {
          "$ref": "#/$defs/current_projection_filters"
        },
        "future_branch_filters": {
          "$ref": "#/$defs/future_branch_filters"
        },
        "layout_hint": {
          "type": "string",
          "minLength": 1
        },
        "group_by": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sort_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "current_projection_filters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_types", "predicates", "row_fields", "node_type_keys", "relation_kind_keys"],
      "properties": {
        "node_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "predicates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "row_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "node_type_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "relation_kind_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "future_branch_filters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_kinds", "relation_kinds"],
      "properties": {
        "node_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "relation_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "path", "message"],
      "properties": {
        "level": {
          "enum": ["warning", "error"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
