{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tree-of-sophia.local/ToS/contracts/philosophy-graph-projection.schema.json",
  "title": "Tree of Sophia philosophy graph projection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "source_refs",
    "content_language_contract",
    "runtime_projection_boundary",
    "validation_refs",
    "counts",
    "visibility_model",
    "snapshot_review",
    "graph_layers",
    "layer_counts",
    "views",
    "nodes",
    "edges",
    "clusters",
    "review_packets",
    "unresolved_review_surfaces",
    "diagnostics"
  ],
  "properties": {
    "schema_version": {
      "const": "tos_philosophy_graph_projection_v1"
    },
    "schema_ref": {
      "const": "ToS/contracts/philosophy-graph-projection.schema.json"
    },
    "owner_repo": {
      "const": "Tree-of-Sophia"
    },
    "surface_kind": {
      "const": "derived_philosophy_graph_projection"
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "atlas_projection_ref",
        "graph_view_catalog_ref",
        "source_view_contract_ref",
        "lens_review_contract_ref",
        "cluster_contract_ref",
        "review_packet_contract_ref"
      ],
      "properties": {
        "atlas_projection_ref": {
          "const": "ToS/derived-exports/philosophy_atlas_projection.min.json"
        },
        "graph_view_catalog_ref": {
          "const": "ToS/derived-exports/philosophy_graph_views.min.json"
        },
        "source_view_contract_ref": {
          "const": "ToS/philosophy/graph-workbench/views/view-contracts.json"
        },
        "lens_review_contract_ref": {
          "const": "ToS/philosophy/graph-workbench/views/lens-review-contracts.json"
        },
        "cluster_contract_ref": {
          "const": "ToS/philosophy/graph-workbench/clusters/cluster-contracts.json"
        },
        "review_packet_contract_ref": {
          "const": "ToS/philosophy/graph-workbench/review-packets/review-packet-contract.json"
        }
      }
    },
    "content_language_contract": {
      "$ref": "#/$defs/content_language_contract"
    },
    "runtime_projection_boundary": {
      "$ref": "#/$defs/runtime_projection_boundary"
    },
    "validation_refs": {
      "$ref": "#/$defs/string_array"
    },
    "counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "visibility_model": {
      "$ref": "#/$defs/visibility_model"
    },
    "snapshot_review": {
      "$ref": "#/$defs/snapshot_review"
    },
    "graph_layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/graph_layer"
      }
    },
    "layer_counts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/layer_count"
      }
    },
    "views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/view"
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/projected_node"
      }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/projected_edge"
      }
    },
    "clusters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/cluster"
      }
    },
    "review_packets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/review_packet"
      }
    },
    "unresolved_review_surfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unresolved_review_surface"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "content_language_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "source_ref",
        "display_languages",
        "required_translation_languages",
        "original_language_rule",
        "downstream_consumer_rule"
      ],
      "properties": {
        "schema_version": {
          "const": "tos_multilingual_content_contract_v1"
        },
        "source_ref": {
          "const": "ToS/philosophy/atlas/multilingual/content-labels.json"
        },
        "display_languages": {
          "$ref": "#/$defs/string_array"
        },
        "required_translation_languages": {
          "$ref": "#/$defs/string_array"
        },
        "original_language_rule": {
          "type": "string",
          "minLength": 1
        },
        "downstream_consumer_rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "multilingual_label": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "label", "language", "translation_status", "source_ref"],
      "properties": {
        "schema_version": {
          "const": "tos_multilingual_label_v1"
        },
        "label": {
          "$ref": "#/$defs/localized_label"
        },
        "language": {
          "$ref": "#/$defs/language_identity"
        },
        "translation_status": {
          "$ref": "#/$defs/translation_status"
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "localized_label": {
      "type": "object",
      "additionalProperties": false,
      "required": ["original", "ru", "en"],
      "properties": {
        "original": {
          "type": ["string", "null"]
        },
        "ru": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "language_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["original_language", "original_script", "transliteration"],
      "properties": {
        "original_language": {
          "type": ["string", "null"]
        },
        "original_script": {
          "type": ["string", "null"]
        },
        "transliteration": {
          "type": ["string", "null"]
        }
      }
    },
    "translation_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["original", "ru", "en"],
      "properties": {
        "original": {
          "enum": ["source", "pending", "not_applicable"]
        },
        "ru": {
          "enum": ["source", "reviewed", "draft"]
        },
        "en": {
          "enum": ["source", "reviewed", "draft"]
        }
      }
    },
    "runtime_projection_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_owner", "runtime_scope", "tos_authority_scope"],
      "properties": {
        "runtime_owner": {
          "const": "abyss-stack"
        },
        "runtime_scope": {
          "$ref": "#/$defs/string_array"
        },
        "tos_authority_scope": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "visibility_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_payload_mode",
        "default_depth",
        "default_limit",
        "layer_ids",
        "expand_returns",
        "cluster_contract_ref",
        "review_packet_contract_ref",
        "lens_review_contract_ref"
      ],
      "properties": {
        "default_payload_mode": {
          "const": "cluster-first"
        },
        "default_depth": {
          "type": "integer",
          "minimum": 0
        },
        "default_limit": {
          "type": "integer",
          "minimum": 1
        },
        "layer_ids": {
          "$ref": "#/$defs/string_array"
        },
        "expand_returns": {
          "$ref": "#/$defs/string_array"
        },
        "cluster_contract_ref": {
          "const": "ToS/philosophy/graph-workbench/clusters/cluster-contracts.json"
        },
        "review_packet_contract_ref": {
          "const": "ToS/philosophy/graph-workbench/review-packets/review-packet-contract.json"
        },
        "lens_review_contract_ref": {
          "const": "ToS/philosophy/graph-workbench/views/lens-review-contracts.json"
        }
      }
    },
    "graph_layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer_id", "use", "source_ref"],
      "properties": {
        "layer_id": {
          "type": "string",
          "minLength": 1
        },
        "use": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "snapshot_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_schema_version", "current_snapshot", "diff_route"],
      "properties": {
        "snapshot_schema_version": {
          "const": "tos_philosophy_graph_projection_snapshot_v1"
        },
        "current_snapshot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["projection_fingerprint", "count_fingerprint", "view_fingerprints"],
          "properties": {
            "projection_fingerprint": {
              "type": "string",
              "minLength": 64,
              "maxLength": 64
            },
            "count_fingerprint": {
              "type": "string",
              "minLength": 64,
              "maxLength": 64
            },
            "view_fingerprints": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/view_fingerprint"
              }
            }
          }
        },
        "diff_route": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "changed_subgraph_available", "previous_snapshot_ref", "next_route"],
          "properties": {
            "mode": {
              "const": "fingerprint-ready"
            },
            "changed_subgraph_available": {
              "const": false
            },
            "previous_snapshot_ref": {
              "type": ["string", "null"]
            },
            "next_route": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "view_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view_id", "fingerprint", "node_count", "edge_count", "cluster_count", "source_ref_count"],
      "properties": {
        "view_id": {
          "type": "string",
          "minLength": 1
        },
        "fingerprint": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "node_count": {
          "type": "integer",
          "minimum": 0
        },
        "edge_count": {
          "type": "integer",
          "minimum": 0
        },
        "cluster_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_ref_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "layer_count": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer_id", "node_count", "edge_count", "view_count", "cluster_count", "source_ref_count"],
      "properties": {
        "layer_id": {
          "type": "string",
          "minLength": 1
        },
        "node_count": {
          "type": "integer",
          "minimum": 0
        },
        "edge_count": {
          "type": "integer",
          "minimum": 0
        },
        "view_count": {
          "type": "integer",
          "minimum": 0
        },
        "cluster_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_ref_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "view_id",
        "title",
        "source_ref",
        "route_card",
        "order",
        "layout_hint",
        "graph_layers",
        "filters_applied",
        "future_branch_filters",
        "review_intent",
        "source_posture",
        "evidence_posture",
        "collapse_rule",
        "ordering_hints",
        "agent_packet_hint",
        "nodes",
        "edges",
        "source_refs",
        "diagnostics"
      ],
      "properties": {
        "view_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "route_card": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "layout_hint": {
          "type": "string",
          "minLength": 1
        },
        "graph_layers": {
          "$ref": "#/$defs/string_array"
        },
        "filters_applied": {
          "type": "object"
        },
        "future_branch_filters": {
          "type": "object"
        },
        "review_intent": {
          "type": "string",
          "minLength": 1
        },
        "source_posture": {
          "type": "string",
          "minLength": 1
        },
        "evidence_posture": {
          "type": "string",
          "minLength": 1
        },
        "collapse_rule": {
          "$ref": "#/$defs/collapse_rule"
        },
        "ordering_hints": {
          "$ref": "#/$defs/string_array"
        },
        "agent_packet_hint": {
          "type": "string",
          "minLength": 1
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/projected_node"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/projected_edge"
          }
        },
        "source_refs": {
          "$ref": "#/$defs/string_array"
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diagnostic"
          }
        }
      }
    },
    "collapse_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_cluster_kinds", "expand_to"],
      "properties": {
        "default_cluster_kinds": {
          "$ref": "#/$defs/string_array"
        },
        "expand_to": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "projected_node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "label", "multilingual", "node_type", "graph_layers", "view_ids", "source_ref", "properties"],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "multilingual": {
          "$ref": "#/$defs/multilingual_label"
        },
        "node_type": {
          "type": "string",
          "minLength": 1
        },
        "graph_layers": {
          "$ref": "#/$defs/string_array"
        },
        "view_ids": {
          "$ref": "#/$defs/string_array"
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "properties": {
          "type": "object"
        }
      }
    },
    "projected_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edge_id", "from_id", "to_id", "predicate_id", "graph_layers", "view_ids", "source_ref", "properties"],
      "properties": {
        "edge_id": {
          "type": "string",
          "minLength": 1
        },
        "from_id": {
          "type": "string",
          "minLength": 1
        },
        "to_id": {
          "type": "string",
          "minLength": 1
        },
        "predicate_id": {
          "type": "string",
          "minLength": 1
        },
        "graph_layers": {
          "$ref": "#/$defs/string_array"
        },
        "view_ids": {
          "$ref": "#/$defs/string_array"
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "properties": {
          "type": "object"
        }
      }
    },
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cluster_id",
        "cluster_kind",
        "label",
        "multilingual",
        "member_key",
        "member_value",
        "member_node_ids",
        "member_edge_ids",
        "view_ids",
        "graph_layers",
        "source_ref",
        "source_refs",
        "properties"
      ],
      "properties": {
        "cluster_id": {
          "type": "string",
          "minLength": 1
        },
        "cluster_kind": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "multilingual": {
          "$ref": "#/$defs/multilingual_label"
        },
        "member_key": {
          "type": "string",
          "minLength": 1
        },
        "member_value": {
          "type": "string",
          "minLength": 1
        },
        "member_node_ids": {
          "$ref": "#/$defs/string_array"
        },
        "member_edge_ids": {
          "$ref": "#/$defs/string_array"
        },
        "view_ids": {
          "$ref": "#/$defs/string_array"
        },
        "graph_layers": {
          "$ref": "#/$defs/string_array"
        },
        "source_ref": {
          "const": "ToS/philosophy/graph-workbench/clusters/cluster-contracts.json"
        },
        "source_refs": {
          "$ref": "#/$defs/string_array"
        },
        "properties": {
          "type": "object"
        }
      }
    },
    "review_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "view_id",
        "review_intent",
        "active_filters",
        "counts",
        "layer_counts",
        "cluster_summaries",
        "weak_source_refs",
        "unresolved_diagnostics",
        "suspicious_dense_hubs",
        "isolated_nodes",
        "candidate_to_canon_pressure",
        "changed_subgraph",
        "recommended_human_review_route",
        "source_refs"
      ],
      "properties": {
        "packet_id": {
          "type": "string",
          "minLength": 1
        },
        "view_id": {
          "type": "string",
          "minLength": 1
        },
        "review_intent": {
          "type": "string",
          "minLength": 1
        },
        "active_filters": {
          "type": "object"
        },
        "counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "layer_counts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/view_layer_count"
          }
        },
        "cluster_summaries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cluster_summary"
          }
        },
        "weak_source_refs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "unresolved_diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/unresolved_review_surface"
          }
        },
        "suspicious_dense_hubs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dense_hub"
          }
        },
        "isolated_nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/isolated_node"
          }
        },
        "candidate_to_canon_pressure": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "changed_subgraph": {
          "type": "object"
        },
        "recommended_human_review_route": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "view_layer_count": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer_id", "node_count", "edge_count", "cluster_count", "source_ref_count"],
      "properties": {
        "layer_id": {
          "type": "string",
          "minLength": 1
        },
        "node_count": {
          "type": "integer",
          "minimum": 0
        },
        "edge_count": {
          "type": "integer",
          "minimum": 0
        },
        "cluster_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_ref_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "cluster_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cluster_id", "cluster_kind", "label", "node_count", "edge_count", "source_ref_count"],
      "properties": {
        "cluster_id": {
          "type": "string",
          "minLength": 1
        },
        "cluster_kind": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "node_count": {
          "type": "integer",
          "minimum": 0
        },
        "edge_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_ref_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "dense_hub": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "label", "degree", "source_ref"],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "degree": {
          "type": "integer",
          "minimum": 0
        },
        "source_ref": {
          "type": "string"
        }
      }
    },
    "isolated_node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "label", "source_ref"],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string"
        }
      }
    },
    "unresolved_review_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_id", "kind", "cluster_kind", "source_ref", "message", "future_member_keys"],
      "properties": {
        "surface_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "const": "unresolved-cluster-family"
        },
        "cluster_kind": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "const": "ToS/philosophy/graph-workbench/clusters/cluster-contracts.json"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "future_member_keys": {
