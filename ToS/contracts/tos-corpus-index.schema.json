{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tree-of-sophia.local/ToS/contracts/tos-corpus-index.schema.json",
  "title": "Tree of Sophia corpus index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "authority_order",
    "runtime_projection_boundary",
    "validation_refs",
    "counts",
    "graph_views",
    "branches",
    "manifests",
    "nodes",
    "relation_packs",
    "relation_edges",
    "resources",
    "diagnostics"
  ],
  "properties": {
    "schema_version": {
      "const": "tos_corpus_index_v1"
    },
    "schema_ref": {
      "const": "ToS/contracts/tos-corpus-index.schema.json"
    },
    "owner_repo": {
      "const": "Tree-of-Sophia"
    },
    "surface_kind": {
      "const": "derived_corpus_index"
    },
    "authority_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/authorityEntry"
      }
    },
    "runtime_projection_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_owner", "allowed", "not_allowed"],
      "properties": {
        "runtime_owner": {
          "const": "abyss-stack"
        },
        "allowed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "not_allowed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validation_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "graph_views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/graphView"
      }
    },
    "branches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/branch"
      }
    },
    "manifests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/manifest"
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "relation_packs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relationPack"
      }
    },
    "relation_edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relationEdge"
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/resource"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    }
  },
  "$defs": {
    "authorityEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer", "owner_branch", "meaning"],
      "properties": {
        "layer": {
          "type": "string",
          "minLength": 1
        },
        "owner_branch": {
          "type": "string",
          "minLength": 1
        },
        "meaning": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "graphView": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view_id", "purpose", "layout_hint", "entry_surface"],
      "properties": {
        "view_id": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "layout_hint": {
          "type": "string",
          "minLength": 1
        },
        "entry_surface": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "branch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "owner_surface", "authority_layer", "role"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "owner_surface": {
          "type": "string",
          "minLength": 1
        },
        "authority_layer": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "manifest_kind", "owner_branch", "authority_layer", "schema_version", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "manifest_kind": {
          "type": "string",
          "minLength": 1
        },
        "owner_branch": {
          "type": "string",
          "minLength": 1
        },
        "authority_layer": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "string"
        },
        "branch_id": {
          "type": ["string", "null"]
        },
        "declared_path": {
          "type": ["string", "null"]
        },
        "sha256": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "node_type", "label", "owner_branch", "authority_layer", "source_path", "source_sha256"],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "node_type": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "owner_branch": {
          "type": "string",
          "minLength": 1
        },
        "authority_layer": {
          "type": "string",
          "minLength": 1
        },
        "source_path": {
          "type": "string",
          "minLength": 1
        },
        "source_sha256": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "route_hint": {
          "type": ["string", "null"]
        }
      }
    },
    "relationPack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pack_id", "path", "route_hint", "owner_branch", "authority_layer", "edge_count", "columns", "sha256"],
      "properties": {
        "pack_id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "route_hint": {
          "type": "string",
          "minLength": 1
        },
        "owner_branch": {
          "type": "string",
          "minLength": 1
        },
        "authority_layer": {
          "type": "string",
          "minLength": 1
        },
        "edge_count": {
          "type": "integer",
          "minimum": 0
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sha256": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        }
      }
    },
    "relationEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edge_id", "pack_id", "from_id", "predicate_id", "to_id", "owner_branch", "authority_layer", "status"],
      "properties": {
        "edge_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_id": {
          "type": "string",
          "minLength": 1
        },
        "from_id": {
          "type": "string"
        },
        "predicate_id": {
          "type": "string"
        },
        "to_id": {
          "type": "string"
        },
        "owner_branch": {
          "type": "string",
          "minLength": 1
        },
        "authority_layer": {
          "type": "string",
          "minLength": 1
        },
        "layer": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "resource_kind", "owner_branch", "authority_layer", "sha256", "size_bytes"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "resource_kind": {
          "type": "string",
          "minLength": 1
        },
        "owner_branch": {
          "type": "string",
          "minLength": 1
        },
        "authority_layer": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "path", "message"],
      "properties": {
        "level": {
          "enum": ["info", "warning", "error"]
        },
        "path": {
          "type": "string"
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
