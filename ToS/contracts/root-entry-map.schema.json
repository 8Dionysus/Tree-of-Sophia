{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/Tree-of-Sophia/main/ToS/contracts/root-entry-map.schema.json",
  "title": "ToS root entry map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "authority_ref",
    "public_root_ref",
    "current_tiny_entry_ref",
    "export_ref",
    "validation_refs",
    "artifact_identity",
    "routes"
  ],
  "properties": {
    "schema_version": {
      "const": "tos_root_entry_map_v1"
    },
    "schema_ref": {
      "const": "ToS/contracts/root-entry-map.schema.json"
    },
    "owner_repo": {
      "const": "Tree-of-Sophia"
    },
    "surface_kind": {
      "const": "root_entry_map"
    },
    "authority_ref": {
      "$ref": "#/$defs/repoRelativeSurface"
    },
    "public_root_ref": {
      "$ref": "#/$defs/repoRelativeSurface"
    },
    "current_tiny_entry_ref": {
      "$ref": "#/$defs/repoRelativeSurface"
    },
    "export_ref": {
      "$ref": "#/$defs/repoRelativeSurface"
    },
    "validation_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/repoRelativeSurface"
      }
    },
    "artifact_identity": {
      "$ref": "#/$defs/artifactIdentity"
    },
    "routes": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/route"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "repoRelativeSurface": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z0-9_-]+:)(?![A-Za-z]:[\\\\/])(?![\\\\/])(?!\\.\\.?[\\\\/])[A-Za-z0-9._/#-]+$"
    },
    "artifactIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_class",
        "surface_state",
        "owner_repo",
        "authority_ref",
        "producer",
        "consumer_expectation",
        "privacy_boundary",
        "content_identity",
        "abi_epoch",
        "contract_version",
        "trust_layer",
        "verification",
        "action"
      ],
      "properties": {
        "artifact_class": {
          "const": "generated_readmodel"
        },
        "surface_state": {
          "const": "public_generated_root_entry_surface"
        },
        "owner_repo": {
          "const": "Tree-of-Sophia"
        },
        "authority_ref": {
          "const": "ToS/derived-exports/AGENTS.md"
        },
        "producer": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "consumer_expectation": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "privacy_boundary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "content_identity": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "abi_epoch": {
          "const": "tos_root_entry_map_v1"
        },
        "contract_version": {
          "const": "ToS/contracts/root-entry-map.schema.json"
        },
        "trust_layer": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "abi_contract_signature",
              "source_schema_validation"
            ]
          }
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "action": {
          "const": "ADD_CONSUMER_EXPECTATION"
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_id",
        "need",
        "surface_ref",
        "verification_refs"
      ],
      "properties": {
        "route_id": {
          "type": "string",
          "minLength": 1
        },
        "need": {
          "type": "string",
          "minLength": 1
        },
        "surface_ref": {
          "$ref": "#/$defs/repoRelativeSurface"
        },
        "verification_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/repoRelativeSurface"
          }
        }
      }
    }
  }
}
