    "questbook_surface": {
      "label": "questbook surface",
      "layer": "mechanics-questbook",
      "mode": "blocking",
      "owner_surface": "mechanics/questbook/AGENTS.md",
      "purpose": "Protect questbook obligations, public quest items, dispatch schemas, and compatibility examples as a mechanics-local validation lane.",
      "command_sequence": "questbook_surface",
      "failure_route": "mechanics/questbook/AGENTS.md",
      "does_not_own": [
        "philosophical source meaning",
        "canon promotion",
        "downstream task runtime"
      ]
    },
    "eval_port": {
      "label": "eval port",
      "layer": "local-eval-port",
      "mode": "advisory",
      "owner_surface": "evals/AGENTS.md",
      "purpose": "Keep ToS-local eval pressure visible while central verdict and scoring authority stay with aoa-evals.",
      "focused_target": "evals/PORT.yaml via aoa-evals validate_local_eval_port.py when aoa-evals is in scope",
      "failure_route": "evals/AGENTS.md",
      "does_not_own": [
        "central eval verdicts",
        "proof doctrine",
        "release blocking without explicit promotion"
      ]
    },
    "graph_exports": {
      "label": "graph exports",
      "layer": "graph-readiness",
      "mode": "blocking",
      "owner_surface": "ToS/derived-exports/tos_corpus_index.min.json",
      "purpose": "Verify corpus graph/read-model exports that abyss-stack can later project and visualize.",
      "command_sequence": "graph_exports",
      "failure_route": "ToS/derived-exports/AGENTS.md",
      "does_not_own": [
        "runtime visualization",
        "MCP service authority",
        "Neo4j or UI cache truth"
      ]
    },
    "release": {
      "label": "release",
      "layer": "release",
      "mode": "blocking",
      "owner_surface": "docs/RELEASING.md",
      "purpose": "Run the current bounded ToS release gate from explicit lane authority.",
      "command_sequence": "release_check",
      "entrypoint": "scripts/release_check.py",
      "covers_lanes": [
        "validation_authority",
        "source_home",
        "philosophy_topology",
        "mechanics_topology",
        "active_naming",
        "generated_parity",
        "canon_contracts",
        "intake_contracts",
        "public_entry",
        "questbook_surface",
        "route_docs"
      ],
      "failure_route": "docs/RELEASING.md",
      "does_not_own": [
        "GitHub publication",
        "federation release audit",
        "future graph runtime checks"
      ]
    }
