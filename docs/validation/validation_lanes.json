{
  "schema_version": "tos_validation_lanes_v1",
  "owner_repo": "Tree-of-Sophia",
  "owner_surface": "docs/validation/README.md",
  "command_authority": "docs/validation/validation_lanes.json",
  "notes": [
    "This manifest is the executable command-authority surface for ToS validation lanes.",
    "scripts/validation_lanes.py is a loader and checker only.",
    "Inventories describe coverage and do not own command execution."
  ],
  "lanes": {
    "validation_authority": {
      "label": "validation authority",
      "layer": "validation",
      "mode": "blocking",
      "owner_surface": "docs/validation/validation_lanes.json",
      "purpose": "Check that named validation lanes remain structured, executable where intended, and separate from descriptive inventories.",
      "command_sequence": "validation_authority",
      "failure_route": "docs/validation/README.md",
      "does_not_own": [
        "source meaning",
        "mechanic package topology",
        "test assertions"
      ]
    },
    "source_home": {
      "label": "source home",
      "layer": "source-home",
      "mode": "blocking",
      "owner_surface": "ToS/source_home.manifest.json",
      "purpose": "Protect the ToS home as a branch-shaped philosophical source home.",
      "command_sequence": "source_home",
      "failure_route": "ToS/AGENTS.md",
      "does_not_own": [
        "mechanics package payloads",
        "runtime graph projection",
        "proof verdict authority"
      ]
    },
    "philosophy_topology": {
      "label": "philosophy topology",
      "layer": "domain-topology",
      "mode": "blocking",
      "owner_surface": "ToS/philosophy/philosophy.manifest.json",
      "purpose": "Protect the philosophy branch from flat imports, UI capture labels, and false source-witness authority.",
      "command_sequence": "philosophy_topology",
      "failure_route": "ToS/philosophy/AGENTS.md",
      "does_not_own": [
        "source witness truth",
        "canon promotion",
        "runtime visualization"
      ]
    },
    "mechanics_topology": {
      "label": "mechanics topology",
      "layer": "mechanics",
      "mode": "blocking",
      "owner_surface": "mechanics/topology.json",
      "purpose": "Protect mechanics packages, active parts, package-local legacy policy, and moved-path accounting.",
      "command_sequence": "mechanics_topology",
      "failure_route": "mechanics/AGENTS.md",
      "does_not_own": [
        "ToS authored meaning",
        "root release publication",
        "central proof authority"
      ]
    },
    "active_naming": {
      "label": "active naming",
      "layer": "active-topology",
      "mode": "blocking",
      "owner_surface": "scripts/validate_active_naming.py",
      "purpose": "Keep retired active path and id names out of current surfaces while allowing archive provenance.",
      "command_sequence": "active_naming",
      "failure_route": "AGENTS.md",
      "does_not_own": [
        "ordinary prose style",
        "legacy archive content",
        "historical changelog language"
      ]
    },
    "generated_parity": {
      "label": "generated parity",
      "layer": "generated-read-model",
      "mode": "blocking",
      "owner_surface": "ToS/derived-exports/AGENTS.md",
      "purpose": "Verify generated read models, indexes, and registries against their source-owned builders.",
      "command_sequence": "generated_parity",
      "failure_route": "ToS/derived-exports/AGENTS.md",
      "does_not_own": [
        "source truth",
        "canon authority",
        "runtime graph caches"
      ]
    },
    "canon_contracts": {
      "label": "canon contracts",
      "layer": "canon-contract",
      "mode": "blocking",
      "owner_surface": "ToS/canon/AGENTS.md",
      "purpose": "Verify canonical node, relation, and public mirror contracts.",
      "command_sequence": "canon_contracts",
      "failure_route": "ToS/canon/AGENTS.md",
      "does_not_own": [
        "candidate promotion decision",
        "source witness interpretation",
        "mechanic process law"
      ]
    },
    "intake_contracts": {
      "label": "intake contracts",
      "layer": "candidate-intake",
      "mode": "blocking",
      "owner_surface": "ToS/candidate-intake/AGENTS.md",
      "purpose": "Verify candidate intake packets without promoting them to canon.",
      "command_sequence": "intake_contracts",
      "failure_route": "ToS/candidate-intake/AGENTS.md",
      "does_not_own": [
        "canon acceptance",
        "source witness truth",
        "public compatibility identity"
      ]
    },
    "route_docs": {
      "label": "route docs",
      "layer": "agent-route-card",
      "mode": "blocking",
      "owner_surface": "scripts/validate_nested_agents.py",
      "purpose": "Verify route-card structure without freezing ordinary prose as doctrine.",
      "command_sequence": "route_docs",
      "failure_route": "DESIGN.AGENTS.md",
      "does_not_own": [
        "philosophical doctrine",
        "decision rationale",
        "release command authority"
      ]
    },
    "public_entry": {
      "label": "public entry",
      "layer": "public-compatibility",
      "mode": "blocking",
      "owner_surface": "ToS/zarathustra/public-entry/TINY_ENTRY_ROUTE.md",
      "purpose": "Protect the bounded public tiny-entry and KAG export seam.",
      "command_sequence": "public_entry",
      "failure_route": "ToS/zarathustra/AGENTS.md",
      "does_not_own": [
        "source witness text",
        "canon identity",
        "aoa-kag substrate semantics"
      ]
